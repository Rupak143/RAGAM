<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_button_white"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:elevation="2dp">

    <!-- Completion Badge -->
    <TextView
        android:id="@+id/completion_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✓ COMPLETED"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@android:color/holo_green_dark"
        android:padding="6dp"
        android:layout_marginBottom="8dp" />

    <!-- Course Title -->
    <TextView
        android:id="@+id/course_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Course Title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="8dp" />

    <!-- Course Description -->
    <TextView
        android:id="@+id/course_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Course description goes here..."
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="8dp"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Instructor Name -->
    <TextView
        android:id="@+id/instructor_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Instructor: John Doe"
        android:textSize="14sp"
        android:textColor="@android:color/black"
        android:layout_marginBottom="12dp" />

    <!-- Videos Completed Text -->
    <TextView
        android:id="@+id/videos_completed_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="6 of 6 videos completed"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@android:color/holo_green_dark" />

</LinearLayout>

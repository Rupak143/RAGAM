<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bguiblue"
    android:padding="20dp">

    <!-- Back Icon -->
    <ImageView
        android:id="@+id/back_button"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_backblack"
        android:layout_alignParentStart="true"
        android:layout_marginTop="60dp"
        android:layout_marginStart="4dp" />

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/back_button"
        android:layout_marginTop="16dp"
        android:layout_above="@+id/bottom_nav"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Page Title -->
            <TextView
                android:id="@+id/page_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Course Setup"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_gravity="center"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="40dp" />

            <!-- Course Category Spinner -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Course Category"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginBottom="8dp" />
            
            <Spinner
                android:id="@+id/course_category_spinner"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/rounded_button_white"
                android:padding="12dp"
                android:layout_marginBottom="24dp" />

            <!-- Course Title -->
            <EditText
                android:id="@+id/course_title"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Course Title"
                android:background="@drawable/rounded_button_white"
                android:padding="12dp"
                android:textColor="@android:color/black"
                android:textColorHint="@android:color/darker_gray"
                android:layout_marginBottom="16dp" />

            <!-- Course Description -->
            <EditText
                android:id="@+id/course_description"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Course Description"
                android:background="@drawable/rounded_button_white"
                android:padding="12dp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:textColor="@android:color/black"
                android:textColorHint="@android:color/darker_gray"
                android:layout_marginBottom="24dp" />

            <!-- Number of Videos -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How many videos will you upload?"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/video_count_input"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Enter number of videos (e.g., 2)"
                android:background="@drawable/rounded_button_white"
                android:padding="12dp"
                android:inputType="number"
                android:textColor="@android:color/black"
                android:textColorHint="@android:color/darker_gray"
                android:layout_marginBottom="40dp" />

            <!-- Next Button -->
            <Button
                android:id="@+id/btn_next"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="NEXT"
                android:background="@drawable/rounded_button_blue"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/ic_home"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/ic_home"
            android:contentDescription="Home"
            android:padding="8dp"
            android:scaleType="centerInside" />
        <ImageView
            android:id="@+id/ic_profile"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/ic_profile"
            android:contentDescription="Profile"
            android:padding="8dp"
            android:scaleType="centerInside" />
    </LinearLayout>
</RelativeLayout>
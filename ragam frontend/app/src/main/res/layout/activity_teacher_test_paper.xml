<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bguiblue"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Back Button -->

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_backblack"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="20dp" />

        <!-- Header -->

        <TextView
            android:id="@+id/course_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Test Paper Creation"
            android:textColor="@android:color/black"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create questions and answers for your course assessment"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="24dp" />

        <!-- Questions Container -->
        <LinearLayout
            android:id="@+id/questions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Add Question Button -->
        <Button
            android:id="@+id/btn_add_question"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="➕ Add Question"
            android:backgroundTint="@color/rounded_button_green"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- Save Test Paper Button -->
        <Button
            android:id="@+id/btn_save_test_paper"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="💾 Save Test Paper"
            android:background="@drawable/rounded_button_green"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>

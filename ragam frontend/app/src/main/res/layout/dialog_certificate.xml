<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white"
    android:gravity="center">

    <!-- Certificate Border -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/certificate_border"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Trophy Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginBottom="5dp"
            android:text="🏆"
            android:textSize="30sp" />

        <!-- Certificate Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:letterSpacing="0.1"
            android:text="CERTIFICATE OF COMPLETION"
            android:textColor="#2196F3"
            android:textSize="10sp"
            android:textStyle="bold" />

        <!-- This is to certify -->

        <!-- Student Name -->
        <TextView
            android:id="@+id/cert_student_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:text="Student Name"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Has successfully completed -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:text="has successfully completed"
            android:textColor="#666666"
            android:textSize="10sp" />

        <!-- Course Name -->
        <TextView
            android:id="@+id/cert_course_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:gravity="center"
            android:text="Course Name"
            android:textColor="#2196F3"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Score Section -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Score: "
                android:textColor="#666666"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/cert_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="95%"
                android:textColor="#4CAF50"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Date of Completion"
            android:textColor="#666666"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/cert_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="1dp"
            android:text="January 01, 2025"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Star Rating -->

    </LinearLayout>

    <!-- Congratulations Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎉 Congratulations! You've earned this certificate! 🎉"
        android:textSize="14sp"
        android:textColor="#4CAF50"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:gravity="center"/>

</LinearLayout>

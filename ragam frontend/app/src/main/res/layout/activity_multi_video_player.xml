<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bguiblue"
    android:padding="20dp">

    <!-- Back Icon -->
    <ImageView
        android:id="@+id/back_button"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_backblack"
        android:layout_alignParentStart="true"
        android:layout_marginTop="60dp"
        android:layout_marginStart="4dp" />

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/back_button"
        android:layout_marginTop="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Course Info Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_button_white"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/course_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Course Title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/instructor_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Instructor: John Doe"
                    android:textSize="16sp"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/course_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Progress: 2/5 videos (40% complete)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/holo_blue_dark"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/instructor_bio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Instructor bio goes here..."
                    android:textSize="14sp"
                    android:textColor="@android:color/darker_gray"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Video Player Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_button_white"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/current_video_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select a video to play"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <VideoView
                    android:id="@+id/video_player"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Videos List Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Course Videos"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginBottom="16dp" />

            <!-- Videos Container -->
            <LinearLayout
                android:id="@+id/videos_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
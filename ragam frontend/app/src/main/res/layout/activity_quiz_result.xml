<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Result Title -->
        <TextView
            android:id="@+id/result_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quiz Results"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"/>

        <!-- Score Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <!-- Score -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Score"
                    android:textSize="16sp"
                    android:textColor="@android:color/darker_gray"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/score_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 0"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginBottom="16dp"/>

                <!-- Percentage -->
                <TextView
                    android:id="@+id/percentage_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_teal"
                    android:layout_marginBottom="16dp"/>

                <!-- Status -->
                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:padding="8dp"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Feedback Text -->
        <TextView
            android:id="@+id/feedback_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Feedback message"
            android:textSize="16sp"
            android:textAlignment="center"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="24dp"
            android:padding="16dp"/>

        <!-- Certificate Button (shown if passed) -->
        <Button
            android:id="@+id/btn_view_certificate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📜 View Certificate"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <!-- Retake Button (shown if failed) -->
        <Button
            android:id="@+id/btn_retake_quiz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Retake Quiz"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <!-- Done Button -->
        <Button
            android:id="@+id/btn_done"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Done"
            android:textSize="16sp"
            android:padding="16dp"
            android:backgroundTint="@android:color/darker_gray"/>

    </LinearLayout>

</ScrollView>
